# ============================================================
# .env.example — MODELO de variáveis de ambiente
# ============================================================
# Este arquivo VAI pro GitHub e serve de checklist: mostra QUAIS
# chaves o projeto precisa, mas NUNCA os valores reais.
#
# Como usar num projeto de cliente:
#   1. Copie este arquivo:   cp .env.example .env
#   2. Preencha os valores reais no .env (ele NÃO vai pro Git — o
#      .gitignore já bloqueia .env).
#   3. No deploy (Vercel), os valores entram nas Environment
#      Variables do projeto, nunca no código.
#
# Cada cliente tem as PRÓPRIAS chaves. Apague os blocos que o
# projeto não usar e adicione os que faltarem.
# ============================================================


# --- App / site ---------------------------------------------
# URL pública do site/app (usada em links, callbacks, SEO)
NEXT_PUBLIC_SITE_URL=
NODE_ENV=


# --- Supabase (auth, banco Postgres, storage) ---------------
# Painel: app.supabase.com -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Conexão direta ao Postgres (migrations / queries server-side)
DATABASE_URL=


# --- Stripe (pagamento / assinatura) ------------------------
# Painel: dashboard.stripe.com -> Developers -> API keys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Webhook (eventos de pagamento): Developers -> Webhooks
STRIPE_WEBHOOK_SECRET=


# --- IA / geração de conteúdo -------------------------------
OPENAI_API_KEY=
# Vídeo (reels) — usar o que o projeto pedir
GEMINI_API_KEY=
FAL_KEY=
HIGGSFIELD_API_KEY=
ANTHROPIC_API_KEY=


# --- Google (Maps, Ads, Analytics) --------------------------
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
GOOGLE_ADS_DEVELOPER_TOKEN=


# --- Meta / Facebook (Ads, conversão) -----------------------
META_ACCESS_TOKEN=
META_PIXEL_ID=


# --- Email transacional (envio de emails) -------------------
# Ex.: Resend, SendGrid, SMTP — depende do projeto
RESEND_API_KEY=
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
